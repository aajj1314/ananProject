APP_NAME=elderly-insole-platform
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./elderly_insole_dev.db
REDIS_URL=redis://localhost:6379/1
JWT_SECRET=dev-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
INFLUXDB_URL=http://localhost:8086
INFLUXDB_TOKEN=dev-token
INFLUXDB_ORG=elderly-care
INFLUXDB_BUCKET=device_location
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_SECONDS=120

# Notification Channels
NOTIFICATION_CHANNELS=in_app,sms,wechat

# SMS Configuration
SMS_PROVIDER=dummy
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# WeChat Configuration
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TEMPLATE_ID=

# Admin Configuration (optional, creates admin user on startup)
ADMIN_PHONE=
ADMIN_PASSWORD=
