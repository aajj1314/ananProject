APP_NAME=elderly-insole-platform
APP_ENV=production
DEBUG=false
API_V1_PREFIX=/api/v1
DATABASE_URL=mysql+aiomysql://user:password@db:3306/elderly_care
REDIS_URL=redis://redis:6379/0
JWT_SECRET=change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
INFLUXDB_URL=http://influxdb:8086
INFLUXDB_TOKEN=change-me
INFLUXDB_ORG=elderly-care
INFLUXDB_BUCKET=device_location
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
CACHE_TTL_SECONDS=120

# Notification Channels
NOTIFICATION_CHANNELS=in_app,sms,wechat

# SMS Configuration
SMS_PROVIDER=dummy
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# WeChat Configuration
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TEMPLATE_ID=
