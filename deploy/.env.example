# Elderly Care Platform - Docker Environment Configuration
# Copy this file to .env and modify as needed

# JWT Secret (REQUIRED: Change this to a secure random string in production!)
JWT_SECRET=your-super-secret-random-key-change-this-in-production

# Application Settings
APP_NAME=elderly-insole-platform
APP_ENV=production
DEBUG=false

# Database (using SQLite by default)
# For MySQL use: DATABASE_URL=mysql+aiomysql://user:password@mysql:3306/elderly_care
DATABASE_URL=sqlite+aiosqlite:///./data/elderly_insole.db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT Configuration
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# Rate Limiting
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# Cache
CACHE_TTL_SECONDS=120

# Notification Channels (comma-separated: in_app,sms,wechat)
NOTIFICATION_CHANNELS=in_app
